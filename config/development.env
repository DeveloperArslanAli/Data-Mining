# Development Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://datamining_user:datamining_pass@localhost:5432/datamining
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
JWT_SECRET=your-development-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Backend API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8090
BACKEND_URL=http://localhost:8090

# Frontend
FRONTEND_URL=http://localhost:3050
NEXT_PUBLIC_API_URL=http://localhost:8090

# Crawling Service
CRAWLING_SERVICE_URL=http://localhost:3001
CRAWLING_SERVICE_PORT=3001

# ML Engine Service
ML_ENGINE_URL=http://localhost:8001
ML_ENGINE_PORT=8001

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================
STORAGE_PATH=./storage
UPLOAD_PATH=./storage/uploads
EXPORT_PATH=./storage/exports
TEMP_PATH=./storage/temp
MAX_FILE_SIZE=1073741824
ALLOWED_FILE_TYPES=csv,json,xml,xlsx,parquet

# =============================================================================
# CRAWLING CONFIGURATION
# =============================================================================
CRAWL_DELAY=1000
CRAWL_TIMEOUT=30000
MAX_CONCURRENT_CRAWLS=5
USER_AGENT=Mozilla/5.0 (compatible; DataMiningBot/1.0)

# =============================================================================
# AI/ML CONFIGURATION
# =============================================================================
OPENAI_API_KEY=your-openai-api-key
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=llama2

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOG_AGGREGATION_URL=

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# =============================================================================
# EMAIL CONFIGURATION (for notifications)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@datamining.com

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGINS=http://localhost:3050,http://127.0.0.1:3050
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/datamining_test
TEST_REDIS_URL=redis://localhost:6379/1

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
ENABLE_SWAGGER=true
ENABLE_DEBUG_TOOLBAR=true
ENABLE_PROFILING=false
