# Production Environment Configuration
# Data Mining Platform - Production Settings

# Application Configuration
ENVIRONMENT=production
APP_NAME=Data Mining Platform
APP_VERSION=1.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8090
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker

# Database Configuration
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
POSTGRES_DB=data_mining_prod
POSTGRES_USER=data_mining_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Security Configuration
SECRET_KEY=your_super_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_SALT_ROUNDS=12

# CORS Configuration
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ML Engine Service Configuration
ML_ENGINE_URL=http://ml-engine:8000
ML_ENGINE_TIMEOUT=300
ML_ENGINE_RETRY_ATTEMPTS=3
ML_ENGINE_RETRY_DELAY=5

# Web Crawling Service Configuration
CRAWLING_SERVICE_URL=http://crawling-service:3000
CRAWLING_SERVICE_TIMEOUT=600
CRAWLING_SERVICE_RETRY_ATTEMPTS=3
CRAWLING_SERVICE_RETRY_DELAY=10

# File Upload Configuration
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=100MB
ALLOWED_FILE_TYPES=csv,xlsx,json,xml,parquet,txt
FILE_STORAGE_BACKEND=local

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_ENDPOINT=/health
READINESS_CHECK_ENDPOINT=/ready

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000
CACHE_BACKEND=redis

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=200

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@yourdomain.com

# External API Keys (if needed)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_ANALYTICS_ID=your_ga_id_here

# SSL/TLS Configuration
SSL_CERT_FILE=/etc/nginx/ssl/cert.pem
SSL_KEY_FILE=/etc/nginx/ssl/key.pem
SSL_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/app/backups

# Performance Configuration
MAX_CONCURRENT_REQUESTS=1000
REQUEST_TIMEOUT=300
KEEP_ALIVE_TIMEOUT=65
MAX_CONNECTIONS=1000

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password_here
GRAFANA_URL=http://grafana:3000

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=data_mining_prod

# API Configuration
API_VERSION=v1
API_PREFIX=/api
API_TITLE=Data Mining Platform API
API_DESCRIPTION=Production API for Data Mining Platform
API_DOCS_URL=/docs
API_REDOC_URL=/redoc

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_ML_SUGGESTIONS=true
ENABLE_WEB_CRAWLING=true
ENABLE_EXPORT_ANALYTICS=true
ENABLE_USER_ACTIVITY_TRACKING=true

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
